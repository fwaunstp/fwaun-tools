# Example anima-tagger configuration.
#
# Drop this file into a dataset directory as `anima-tagger.toml` for
# project-local options, or keep a copy at
# `~/.config/anima-tagger/config.toml` (resp.
# `$XDG_CONFIG_HOME/anima-tagger/config.toml`) for user-wide defaults.
# Per-directory entries win on key collision; everything is optional and
# falls back to the built-in defaults if the file is absent.

# Selectors: which profile each subcommand uses when invoked without
# `--profile` / `--model`. Comment any of them out to fall back to the
# built-ins (anima export profile, wd-eva02-large-v3 tagger,
# qwen3-vl-4b captioner).
default_profile   = "anima"
default_tagger    = "wd-eva02-large-v3"
default_captioner = "qwen3-vl-4b"

# ---------------------------------------------------------------------------
# Export profiles — control how tags/captions are filtered/formatted on
# `export` (one .txt per image) and `metadata`. `metadata --format
# sd-scripts` writes one meta.json (tags + captions); `metadata --format
# musubi` writes a caption-only meta.jsonl for musubi-tuner.
# ---------------------------------------------------------------------------

[export.anima]
# Score cutoff applied to auto tags at export time.
threshold = 0.35
# sd-scripts shuffles tag order at training time, so leave this off.
shuffle = false
# Drop auto tags whose category is in this list (e.g. "meta", "rating").
exclude_categories = []

# Per-category prefix applied to auto tags. ANIMA expects `@artist_name`.
[export.anima.category_prefixes]
artist = "@"

[export.plain]
threshold = 0.35
shuffle = false
exclude_categories = []

# (no per-category prefixes for plain training)
[export.plain.category_prefixes]

# Caption-only profile for musubi-tuner (`metadata --format musubi`) or any
# caption-driven trainer. The caption carries the description; tags that mark
# a controllable mode are folded into a deterministic caption prefix instead
# of being emitted as tags.
[export.musubi]
threshold = 0.35
shuffle = false
exclude_categories = []

# Caption-only output → no per-category tag prefixes.
[export.musubi.category_prefixes]

# Fold curation tags into a caption prefix. On caption export, if the image
# has a positive manual tag matching a key here (matched case-insensitively,
# a leading organizational `_` is ignored), the value is prepended verbatim
# to the caption — include your own trailing separator. Multiple matches are
# emitted in key order. Example below: a head-to-body trigger for a single
# art-style LoRA. Give every mode its own explicit token (including the
# "default" look) — an unmarked default tends to drift toward whichever mode
# dominates the set rather than staying put.
[export.musubi.caption_prefixes]
realistic = "realistic proportions, "
standard = "stylized proportions, "
super_deformed = "super deformed, "

# Caption suffixes — same matching as prefixes, but appended to the end.
# Use these for trainers / inference templates that expect the trigger word
# as a trailing tag. ComfyUI's Krea-2 template, for instance, concatenates
# the LoRA trigger onto the end of the prompt (`{prompt}, {trigger}`) using a
# natural-language "... style" phrase, so a caption trained the same way
# (`{description}, {trigger}`) lines up at inference. Include your own leading
# separator (here `", "`). Configure prefixes OR suffixes per profile — you
# don't normally want both.
[export.musubi.caption_suffixes]
realistic = ", fwaun style, realistic proportions"
standard = ", fwaun style, stylized proportions"
super_deformed = ", fwaun style, chibi proportions"

# ---------------------------------------------------------------------------
# Captioner prompt library — define each prompt once here and reference
# it by name from any captioner profile's `prompts = [...]`. The built-in
# `default` is always available; redefining it here overrides the
# built-in. Per-image specifics (character names + positions) belong in
# `caption_hint` on the sidecar, not in these prompts.
# ---------------------------------------------------------------------------

[captioner_prompts]
# Override the built-in default if you want a different baseline.
# default = "Describe this image briefly."

# Character-focused prompt: useful for character LoRAs where you want
# the model to weave per-character details into the description.
# Combine with `caption_hint` ("Left girl is Alice; right boy is Bob.")
# to lock in names — the captioner sees both at generation time and
# stitches them into one cohesive caption rather than a manual prefix.
character = "Describe this image with attention to each person — their appearance (hair, clothing, expression), pose, and where they sit in the frame. 3-5 sentences, under 200 words."

# ---------------------------------------------------------------------------
# Tagger profiles — HuggingFace-hosted WD14-family models. Models are
# downloaded into the shared hf-hub cache on first use.
# ---------------------------------------------------------------------------

[tagger.wd-eva02-large-v3]
repo = "SmilingWolf/wd-eva02-large-tagger-v3"
# Pin a branch / tag / commit. Defaults to the repo's `main` if omitted.
revision = "main"
input_size = 448
# Tags scoring below this are dropped before being stored in the sidecar,
# leaving room to re-filter with a lower `threshold` at export time
# without re-running inference.
storage_threshold = 0.10

# ---------------------------------------------------------------------------
# Captioner profiles. Use `kind = "onnx"` for a local HF-hosted ONNX
# pipeline, or `kind = "openai"` to call any OpenAI-compatible
# chat-completions endpoint (llama.cpp, koboldcpp, Ollama, LM Studio,
# vLLM, ...).
#
# Token budget note: ANIMA is trained with qwen3_max_token_length =
# t5_max_token_length = 512 (kohya-ss anima_train_network defaults), so
# captions longer than ~512 tokens get truncated at training time.
#
# IMPORTANT: each captioner's `max_new_tokens` / `max_tokens` is measured
# in *that captioner model's own tokenizer*, NOT ANIMA's. The numbers
# don't compare directly:
#   * Qwen3-VL (ONNX) shares Qwen3 vocab with ANIMA, so 512 here ≈ 512
#     ANIMA tokens. Don't go over.
#   * Gemma-3 / other OpenAI backends use different vocabs that need
#     1.5-2.3x more tokens to encode the same English prose. So 512 of
#     Gemma's tokens often comes out to ~250 ANIMA tokens — the cap
#     becomes overly conservative and produces mid-sentence cutoffs.
#     Bump `max_tokens` to 800-1024 for those backends; the prompt's
#     length cap (`under 200 words`) still keeps prose bounded, and you
#     can verify against ANIMA's real budget with `anima-tagger tokens`.
#
# `prompts = ["..."]` is a list of names looked up in
# `[captioner_prompts]`. Each named prompt produces its own caption
# entry under the same loaded model, keyed `{profile}.{name}` in the
# sidecar — so adding a prompt is essentially free (one extra inference
# per image, no extra model load). Omit the field to default to
# `["default"]`.
# ---------------------------------------------------------------------------

[captioner.qwen3-vl-4b]
kind = "onnx"
repo = "onnx-community/Qwen3-4B-VL-ONNX"
revision = "main"
# onnx-community packs multiple variants per repo under variant-named
# subdirectories. Leave empty / `""` for forks that put the ONNX files
# at the repo root.
subdir = "qwen3-vl-4b-instruct-onnx-vision-fp32-text-int4-cpu"
# Smart-resize area cap (~768x768). Larger = richer captions, quadratically
# slower decode.
max_pixels = 589824
max_new_tokens = 512
prompts = ["default"]

[captioner.local-llamacpp]
kind = "openai"
# Base URL up to and including `/v1` (we append `/chat/completions`).
endpoint = "http://localhost:8080/v1"
# Sent verbatim as the chat-completions `model` field. Many local servers
# ignore it; some require a non-empty value.
model = "local"
# Bearer token. Empty string / omit for unauthenticated local servers.
api_key = ""
# Counted in this server's tokenizer, not ANIMA's. Bump to 800-1024
# for Gemma-style models if you see mid-sentence truncation; verify
# with `anima-tagger tokens` after generation.
max_tokens = 512
temperature = 0.7
# Resize so the longest edge is at most this many pixels before sending.
# 0 = send the file bytes verbatim.
max_edge = 1024
jpeg_quality = 90
# Per-request timeout. CPU-bound local servers can need several minutes
# for a single caption.
timeout_secs = 600
# Retry a request that fails with a transient error (HTTP 5xx or a
# transport/network failure) up to this many times before giving up. Helps
# with servers that intermittently 500 — e.g. gpt-oss harmony parse errors.
# 0 = never retry.
max_retries = 3
# Run two prompts per image: one general description and one focused on
# characters. Both share the same loaded model.
prompts = ["default", "character"]

# ---------------------------------------------------------------------------
# Tag groups — declare sets of tags that should be mutually exclusive on
# each image. Used by `anima-tagger validate-tag-group` and the GUI's
# Kanban view to bucket images per-tag, plus an "unset" and "violation"
# (multiple tags coexisting) bucket.
#
# Two or more group tags coexisting on one image is a "violation", but
# this is informational rather than an error — character setting sheets
# legitimately show multiple costumes in one frame.
# ---------------------------------------------------------------------------

# Costume separation for a character LoRA where the official material
# offers a school uniform and lounge wear. Each training image should
# fall into exactly one of: `official_school_uniform`,
# `official_lounge_wear`, or "unset" (use `-foo` markers in
# `manual_tags` to opt out of both).
[tag_group.official_costumes]
tags = ["official_school_uniform", "official_lounge_wear"]

# Single-tag groups are valid too — handy for "is tag X set or not?"
# curation passes. Uncomment and edit:
# [tag_group.solo_check]
# tags = ["solo"]

# Curation-only "organizational" tags: a positive manual entry starting with
# an underscore (`_foo`) is kept in the data and counted for tag-group
# classification, but is NEVER written to the exported `.txt`. This lets you
# tell apart "not yet reviewed" (no group tag at all → the Kanban "unset"
# column) from "reviewed, deliberately none of these" (an organizational tag).
# Add such a tag as a group member to give "confirmed none" its own column:
# [tag_group.character]
# tags = ["character_a", "character_b", "_no_character"]
